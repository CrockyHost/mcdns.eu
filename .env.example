# Application
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-with-a-random-secret
APP_BASE_URL=https://mcdns.eu
DEFAULT_URI=https://mcdns.eu

# Database
# Replace each placeholder with the values created in cPanel's MySQL Database Wizard.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME?serverVersion=8.0.0&charset=utf8mb4"

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_BASE_DOMAIN=mcdns.eu

# Services
MAILER_DSN=null://null
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
